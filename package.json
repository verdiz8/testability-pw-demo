{
  "name": "testability-pw-demo",
  "version": "1.0.0",
  "description": "Playwright E2E test automation framework for Conduit (Bondar Academy)",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "report": "npx playwright show-report",
    "report:allure": "npx allure generate allure-results --clean -o allure-report && npx allure open allure-report"
  },
  "keywords": ["playwright", "e2e", "test-automation", "conduit"],
  "author": "verdiz8",
  "license": "ISC",
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "allure-playwright": "^3.10.2",
    "typescript": "^7.0.2"
  }
}
